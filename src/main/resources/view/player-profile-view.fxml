<!--                                <Label text="START DATE" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12; -fx-font-weight: bold;"/>-->
<!--                                <Label fx:id="startDateLabel" text="-" style="-fx-text-fill: #2c3e50; -fx-font-size: 17;"/>-->
<!--                            </VBox>-->
<!--                            <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="0">-->
<!--                                <Label text="END DATE" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12; -fx-font-weight: bold;"/>-->
<!--                                <Label fx:id="endDateLabel" text="-" style="-fx-text-fill: #c0392b; -fx-font-size: 17; -fx-font-weight: bold;"/>-->
<!--                            </VBox>-->
<!--                            <VBox spacing="2" GridPane.columnIndex="0" GridPane.rowIndex="1">-->
<!--                                <Label text="MONTHLY WAGE" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12; -fx-font-weight: bold;"/>-->
<!--                                <Label fx:id="wageLabel" text="0.00 €" style="-fx-text-fill: #27ae60; -fx-font-size: 19; -fx-font-weight: bold;"/>-->
<!--                            </VBox>-->
<!--                            <VBox spacing="2" GridPane.columnIndex="1" GridPane.rowIndex="1">-->
<!--                                <Label text="PERFORMANCE BONUS" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12; -fx-font-weight: bold;"/>-->
<!--                                <Label fx:id="bonusLabel" text="0.00 €" style="-fx-text-fill: #27ae60; -fx-font-size: 19;"/>-->
<!--                            </VBox>-->
<!--                            <VBox spacing="2" GridPane.columnSpan="2" GridPane.rowIndex="2">-->
<!--                                <Label text="BONUS DESCRIPTION" style="-fx-text-fill: #7f8c8d; -fx-font-size: 12; -fx-font-weight: bold;"/>-->
<!--                                <Label fx:id="bonusDescLabel" text="No additional bonuses described." wrapText="true" style="-fx-text-fill: #2c3e50; -fx-font-size: 15; -fx-font-style: italic;"/>-->
<!--                            </VBox>-->
<!--                        </GridPane>-->
<!--                    </VBox>-->
                </HBox>
            </VBox>

            <HBox alignment="CENTER" maxWidth="1000.0">
                <Button fx:id="saveBtn" text="+ Update Player Profile" prefHeight="40.0" prefWidth="220.0"
                        style="-fx-background-color: white; -fx-text-fill: #006ddb; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>