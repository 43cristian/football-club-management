<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #006ddb;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="iss.controller.AddPlayerController">

    <BorderPane prefHeight="150.0">
        <padding>
            <Insets top="20" right="40" bottom="20" left="40"/>
        </padding>
        <left>
            <VBox alignment="CENTER_LEFT" spacing="15">
                <Button fx:id="backBtn" text="&lt; Back to Squad" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;"/>
                <VBox alignment="CENTER_LEFT" spacing="5">
                    <HBox spacing="5">
                        <Label text="Logged in as:" style="-fx-text-fill: white; -fx-font-size: 18;"/>
                        <Label fx:id="usernameLabel" text="[username]" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label fx:id="userTypeLabel" text="[usertype]" style="-fx-text-fill: white; -fx-font-size: 16;"/>
                </VBox>
            </VBox>
        </left>
        <center>
            <ImageView fitHeight="80.0" preserveRatio="true">
                <image>
                    <Image url="@/images/fcm-logo-main.png" />
                </image>
            </ImageView>
        </center>
        <right>
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="clubNameLabel" text="[clubname]" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                    <Label fx:id="clubNationLabel" text="[clubnation]" style="-fx-text-fill: white; -fx-font-size: 16;"/>
                </VBox>
                <ImageView fx:id="clubLogoView" fitHeight="70.0" fitWidth="70.0" preserveRatio="true"/>
            </HBox>
        </right>
    </BorderPane>

    <StackPane VBox.vgrow="ALWAYS">
        <VBox maxWidth="600.0" maxHeight="500.0" spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <Label text="New Player Details" style="-fx-text-fill: #006ddb; -fx-font-size: 24; -fx-font-weight: bold;"/>

            <Separator />

            <GridPane hgap="20" vgap="15">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="First Name" style="-fx-text-fill: #006ddb; -fx-font-weight: bold;"/>
                    <TextField fx:id="firstNameField" prefHeight="35.0" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Last Name" style="-fx-text-fill: #006ddb; -fx-font-weight: bold;"/>
                    <TextField fx:id="lastNameField" prefHeight="35.0" />
                </VBox>

                <VBox spacing="5" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Label text="Birth Date" style="-fx-text-fill: #006ddb; -fx-font-weight: bold;"/>
                    <DatePicker fx:id="birthDatePicker" prefHeight="35.0" prefWidth="Infinity" />
                </VBox>
                <VBox spacing="5" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Label text="Shirt Number" style="-fx-text-fill: #006ddb; -fx-font-weight: bold;"/>
                    <TextField fx:id="shirtNumberField" prefHeight="35.0" />
                </VBox>

                <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="2">
                    <Label text="Nationality" style="-fx-text-fill: #006ddb; -fx-font-weight: bold;"/>
                    <TextField fx:id="nationalityField" prefHeight="35.0" />
                </VBox>

                <VBox spacing="5" GridPane.columnSpan="2" GridPane.rowIndex="3">
                    <Label text="Positions (CTRL + Click for multiple)" style="-fx-text-fill: #006ddb; -fx-font-weight: bold;"/>
                    <ListView fx:id="positionsListView" prefHeight="100.0" />
                </VBox>
            </GridPane>

            <HBox alignment="CENTER_RIGHT" spacing="15">
                <padding>
                    <Insets top="10"/>
                </padding>
                <Button fx:id="saveBtn" text="Add Player" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </StackPane>
</VBox>
