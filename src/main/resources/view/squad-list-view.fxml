<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #006ddb;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="iss.controller.SquadListController">

    <BorderPane prefHeight="150.0">
        <padding>
            <Insets top="20" right="40" bottom="20" left="40"/>
        </padding>

        <left>
            <VBox alignment="CENTER_LEFT" spacing="15">
                <Button fx:id="backBtn" text="&lt; Back to Dashboard" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 0;"/>

                <VBox alignment="CENTER_LEFT" spacing="5">
                    <HBox spacing="5">
                        <Label text="Logged in as:" style="-fx-text-fill: white; -fx-font-size: 18;"/>
                        <Label fx:id="usernameLabel" text="[username]" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label fx:id="userTypeLabel" text="[usertype]" style="-fx-text-fill: white; -fx-font-size: 16;"/>
                </VBox>
            </VBox>
        </left>

        <center>
            <ImageView fitHeight="80.0" preserveRatio="true">
                <image>
                    <Image url="@/images/fcm-logo-main.png" />
                </image>
            </ImageView>
        </center>

        <right>
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="clubNameLabel" text="[clubname]" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                    <Label fx:id="clubNationLabel" text="[clubnation]" style="-fx-text-fill: white; -fx-font-size: 16;"/>
                </VBox>
                <ImageView fx:id="clubLogoView" fitHeight="70.0" fitWidth="70.0" preserveRatio="true"/>
            </HBox>
        </right>
    </BorderPane>

    <HBox alignment="CENTER_LEFT">
        <padding>
            <Insets left="40" bottom="10"/>
        </padding>
        <Label text="Squad List" style="-fx-text-fill: white; -fx-font-size: 42; -fx-font-family: 'Serif';"/>
    </HBox>

    <VBox VBox.vgrow="ALWAYS" spacing="10">
        <padding>
            <Insets left="40" right="40" bottom="20"/>
        </padding>

        <TableView fx:id="squadTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 18; -fx-base: white; -fx-control-inner-background: white; -fx-table-cell-border-color: transparent; -fx-cursor: hand;">
            <columns>
                <TableColumn fx:id="colNumber" text="#" prefWidth="100"
                             style="-fx-alignment: CENTER; -fx-text-fill: #006ddb; -fx-font-weight: bold;" />

                <TableColumn fx:id="colName" text="Name" prefWidth="350"
                             style="-fx-alignment: CENTER_LEFT; -fx-text-fill: #006ddb; -fx-padding: 0 0 0 20;" />

                <TableColumn fx:id="colPosition" text="Positions" prefWidth="350"
                             style="-fx-alignment: CENTER; -fx-text-fill: #006ddb;" />

                <TableColumn fx:id="colNationality" text="Nationality" prefWidth="300"
                             style="-fx-alignment: CENTER_LEFT; -fx-text-fill: #006ddb; -fx-padding: 0 0 0 20;" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox alignment="CENTER">
            <padding>
                <Insets top="5"/>
            </padding>
            <Button fx:id="addPlayerBtn" text="+ Add New Player" prefHeight="40.0" prefWidth="180.0"
                    style="-fx-background-color: white; -fx-text-fill: #006ddb; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

</VBox>