<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #006ddb;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="iss.controller.MainDashboardController">

    <BorderPane prefHeight="150.0">
        <padding>
            <Insets bottom="20" left="40" right="40" top="20" />
        </padding>

        <left>
            <VBox alignment="CENTER_LEFT" spacing="5">
                <HBox spacing="5">
                    <Label style="-fx-text-fill: white; -fx-font-size: 18;" text="Logged in as:" />
                    <Label fx:id="usernameLabel" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="[username]" />
                </HBox>
                <Label fx:id="userTypeLabel" style="-fx-text-fill: white; -fx-font-size: 16;" text="[usertype]" />
            </VBox>
        </left>

        <center>
            <ImageView fitHeight="80.0" preserveRatio="true">
                <image>
                    <Image url="@/images/fcm-logo-main.png" />
                </image>
            </ImageView>
        </center>

        <right>
            <HBox alignment="CENTER_RIGHT" spacing="15">
                <VBox alignment="CENTER_RIGHT">
                    <Label fx:id="clubNameLabel" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" text="[clubname]" />
                    <Label fx:id="clubNationLabel" style="-fx-text-fill: white; -fx-font-size: 16;" text="[clubnation]" />
                </VBox>
                <ImageView fx:id="clubLogoView" fitHeight="100.0" fitWidth="100.0" preserveRatio="true">
                </ImageView>
            </HBox>
        </right>
    </BorderPane>

    <HBox alignment="CENTER_LEFT" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="40" left="40" right="40" />
        </padding>

        <HBox spacing="30" alignment="CENTER">
            <padding>
                <Insets top="20" bottom="20" left="20" right="20"/>
            </padding>

            <StackPane fx:id="squadListBtn" prefHeight="450.0" prefWidth="300.0" style="-fx-cursor: hand;">
                <ImageView fitHeight="450.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="false">
                    <image>
                        <Image url="@/images/squad-list-tab.jpg" />
                    </image>
                </ImageView>

                <VBox alignment="TOP_LEFT" style="-fx-background-color: rgba(0,0,0,0.4);"> <padding>
                    <Insets left="20" top="20" />
                </padding>
                    <Label style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 10, 0, 0, 0);" text="Squad List" />
                </VBox>
            </StackPane>

            <StackPane prefHeight="450.0" prefWidth="300.0" style="-fx-cursor: hand;">
                <ImageView fitHeight="450.0" fitWidth="300.0" pickOnBounds="true" preserveRatio="false">
<!--                    <image>-->
<!--                        <Image url="@/images/squad-list-tab.jpg" />-->
<!--                    </image>-->
                </ImageView>

                <VBox alignment="TOP_LEFT" style="-fx-background-color: rgba(0,0,0,0.4);">
                    <padding>
                        <Insets left="20" top="20" />
                    </padding>
                    <Label style="-fx-text-fill: white; -fx-font-size: 32; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.8), 10, 0, 0, 0);" text="Coming Soon" />
                </VBox>
            </StackPane>
        </HBox>

    </HBox>

</VBox>
